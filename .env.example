# Variáveis de ambiente do backend (copie para .env e ajuste)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/imobiliaria_alpha?schema=public"
PORT=3001

# Sincronização com o ERP (Imobnode) — URL completa gerada em
# /imoveis/portais (card "Site próprio" → "Gerar link de sincronização").
# O backend consulta essa URL periodicamente e atualiza os imóveis.
ERP_SYNC_URL=""
ERP_SYNC_INTERVAL_MS=300000

FRONTEND_URL="http://localhost:5173"

# Widget de chat do Chatwoot (usado pelo formulário "Agendar Visita"). Mesma
# instância pra todos os tenants — só o website_token (sincronizado do ERP,
# ver SiteSettings.chatwootWebsiteToken) muda por tenant. Precisa do
# prefixo VITE_ pra ficar disponível no código do frontend (Vite).
VITE_CHATWOOT_BASE_URL=""
